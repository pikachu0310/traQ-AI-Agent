# Common
BOT_MODE=mock
BOT_TRIGGER_PREFIX=/codex
BOT_DATA_DIR=./data
CODEX_WORKING_DIR=.

# Codex runner
CODEX_COMMAND=codex
CODEX_MODEL=
CODEX_REASONING_EFFORT=medium
# Optional: comma/space separated flags passed as `--enable <flag>`
CODEX_ENABLE_FEATURES=
CODEX_DANGEROUS_BYPASS=true
CODEX_HOME_TEMPLATE_DIR=./data/runtime/codex-home
CODEX_AUTH_SOURCE=~/.codex/auth.json

# MCP servers (default: mastra_local + optional traq_api)
# Optional full override as JSON array:
# MCP_SERVERS_JSON=[{"name":"mastra_local","command":"node","args":["--import","tsx","apps/mastra-mcp/src/index.ts"],"cwd":"."}]
MCP_SERVERS_JSON=
MCP_SERVER_NAME=mastra_local
MCP_SERVER_COMMAND=node
MCP_SERVER_ARGS=--import tsx apps/mastra-mcp/src/index.ts
MCP_SERVER_CWD=.
TRAQ_MCP_ENABLED=
TRAQ_MCP_SERVER_NAME=traq_api
TRAQ_MCP_COMMAND=node
TRAQ_MCP_ARGS=--import tsx apps/traq-mcp/src/index.ts
TRAQ_MCP_CWD=.
TRAQ_OPENAPI_URL=https://raw.githubusercontent.com/traPtitech/traQ/master/docs/v3-api.yaml
TRAQ_OPENAPI_LOCAL_PATH=
TRAQ_OPENAPI_CACHE_TTL_MS=300000
TRAQ_OPENAPI_FETCH_TIMEOUT_MS=15000
TRAQ_MCP_ALLOWED_OPERATION_IDS=

# traQ real mode
TRAQ_BOT_TOKEN=
TRAQ_WS_URL=wss://q.trap.jp/api/v3/bots/ws
TRAQ_API_BASE_URL=https://q.trap.jp/api/v3
TRAQ_BOT_USER_ID=

# Mock mode
MOCK_CHANNEL_ID=mock-channel
MOCK_THREAD_ID=mock-thread
MOCK_USER_ID=mock-user
MOCK_TEXT=/codex Mastra MCP の demo service status を取得して要約してください。
